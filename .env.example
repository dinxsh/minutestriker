# Server-only hackathon envs. Do not expose the Builder API key with a VITE_ prefix.
BENTO_URL=https://internal-server.bento.fun

# Official docs use BENTO_BUILDER_API_KEY. Hackathon notes may say BUILDER_API_KEY.
# The backend accepts either name.
BENTO_BUILDER_API_KEY=replace_with_bento_builder_api_key
BUILDER_API_KEY=replace_with_bento_builder_api_key

# Optional: enables Bento tournaments/parlay surfaces when implemented.
# Hackathon repo spells this as TOURNMENT; keep that exact spelling.
PARLAY_TOURNMENT_URL=https://bento-fun-tournaments-backend-3nku.onrender.com

# Legacy TxLINE envs are no longer used by the active app path.
